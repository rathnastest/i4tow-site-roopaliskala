---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { BlockRenderer } from '@/components/blocks';
import type { Block } from '@/lib/blocks';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter((p) => (p.data.slug ?? p.id) !== 'home')
    .map((p) => ({ params: { slug: p.data.slug ?? p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const blocks = (entry.data.blocks ?? []) as unknown as Block[];
const settings = blocks.find((block) => block.kind === 'siteSettings');
const themeId = settings?.kind === 'siteSettings' ? settings.themeId : undefined;
const fontId = settings?.kind === 'siteSettings' ? settings.fontId : undefined;
const primaryColor = settings?.kind === 'siteSettings' ? settings.primaryColor : undefined;
const secondaryColor = settings?.kind === 'siteSettings' ? settings.secondaryColor : undefined;
const backgroundColor = settings?.kind === 'siteSettings' ? settings.backgroundColor : undefined;
const lightPrimaryColor = settings?.kind === 'siteSettings' ? settings.lightPrimaryColor : undefined;
const lightSecondaryColor = settings?.kind === 'siteSettings' ? settings.lightSecondaryColor : undefined;
const lightBackgroundColor = settings?.kind === 'siteSettings' ? settings.lightBackgroundColor : undefined;
const darkPrimaryColor = settings?.kind === 'siteSettings' ? settings.darkPrimaryColor : undefined;
const darkSecondaryColor = settings?.kind === 'siteSettings' ? settings.darkSecondaryColor : undefined;
const darkBackgroundColor = settings?.kind === 'siteSettings' ? settings.darkBackgroundColor : undefined;
const appearanceModeEnabled = settings?.kind === 'siteSettings' ? settings.appearanceModeEnabled : undefined;
const logoUrl = settings?.kind === 'siteSettings' ? settings.logoUrl : undefined;
const pageWidth = settings?.kind === 'siteSettings' ? settings.pageWidth : undefined;
---
<BaseLayout title={entry.data.title} description={entry.data.description} ogImage={entry.data.ogImage} themeId={themeId} fontId={fontId} primaryColor={primaryColor} secondaryColor={secondaryColor} backgroundColor={backgroundColor} lightPrimaryColor={lightPrimaryColor} lightSecondaryColor={lightSecondaryColor} lightBackgroundColor={lightBackgroundColor} darkPrimaryColor={darkPrimaryColor} darkSecondaryColor={darkSecondaryColor} darkBackgroundColor={darkBackgroundColor} appearanceModeEnabled={appearanceModeEnabled} logoUrl={logoUrl} pageWidth={pageWidth}>
  <BlockRenderer blocks={blocks} client:load />
</BaseLayout>
